    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "视力员工",
    "navigationBarBackgroundColor": "#1677FF",
    "backgroundColor": "#F5F7FA"
  },
  "_tabBarReplaced": "原生 tabBar 已替换为悬浮自定义组件 components/floating-tabbar.vue（在 5 个 tab 页面底部插入），不再使用 pages.json tabBar 配置。"
