      }
    },
    {
      "path": "pages/customer/conflict",
      "style": {
        "navigationBarTitleText": "冲突合并"
      }
    },
    {
      "path": "pages/follow-up/list",
      "style": {
        "navigationBarTitleText": "跟进日志",
