      }
    },
    {
      "path": "pages/follow-up/new",
      "style": {
        "navigationBarTitleText": "写跟进"
      }
    },
    {
      "path": "pages/follow-up/detail",
      "style": {
        "navigationBarTitleText": "跟进详情"
