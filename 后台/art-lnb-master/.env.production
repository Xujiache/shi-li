# 【生产】环境变量

# 权限模式：当前项目由前端静态路由控制菜单
VITE_ACCESS_MODE=frontend

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 地址前缀
VITE_API_URL = https://api.xujiacheng.top

# Node 后端模式下不再使用 CloudBase HTTP 网关
VITE_CLOUDBASE_HTTP_URL=
VITE_CLOUDBASE_PUBLISHABLE_KEY=

# Delete console
VITE_DROP_CONSOLE = true