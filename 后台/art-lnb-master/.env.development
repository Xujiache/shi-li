# 【开发】环境变量

# 权限模式：当前项目由前端静态路由控制菜单
VITE_ACCESS_MODE=frontend

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 请求基础路径（开发环境设置为 / 使用代理，生产环境设置为完整后端地址）
VITE_API_URL = /

# 代理目标地址（开发环境通过 Vite 代理转发到 HTTPS API 域名）
VITE_API_PROXY_URL = https://api.xujiacheng.top

# Node 后端模式下不再使用 CloudBase HTTP 网关
VITE_CLOUDBASE_HTTP_URL =
VITE_CLOUDBASE_PUBLISHABLE_KEY =

# Delete console
VITE_DROP_CONSOLE = false