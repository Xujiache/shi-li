.field {
  width: 100%;
}

.label-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.label {
  font-size: 26rpx;
  color: var(--text-200);
}

.required {
  margin-left: 6rpx;
  color: #ff4d4f;
  font-size: 26rpx;
}

.meta {
  margin-left: auto;
  color: var(--text-200);
  font-size: 24rpx;
}

.control {
  background: #ffffff;
  border-radius: 16rpx;
  border: 1px solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.04);
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
}

.text {
  font-size: 32rpx;
  color: var(--text-100);
}

.text.placeholder {
  color: rgba(0,0,0,0.35);
  font-size: 28rpx;
}

.arrow {
  color: rgba(0,0,0,0.35);
  font-size: 34rpx;
  margin-left: 20rpx;
}

.is-focus .control {
  border-color: rgba(0, 119, 194, 0.75);
  box-shadow: 0 10rpx 24rpx rgba(0, 119, 194, 0.16);
  transform: translateY(-2rpx);
}

.is-error .control {
  border-color: rgba(255, 77, 79, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(255, 77, 79, 0.14);
}

.is-disabled .control {
  background: #f4f6f8;
  border-color: rgba(0, 0, 0, 0.06);
  box-shadow: none;
}

.help {
  margin-top: 10rpx;
}

.help-text {
  font-size: 24rpx;
  color: var(--text-200);
}

.help-text.err {
  color: #ff4d4f;
}

