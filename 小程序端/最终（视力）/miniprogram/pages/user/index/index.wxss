.container {
  padding: 20rpx;
  background: var(--bg-200);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 220rpx;
  position: relative;
  /* 覆写全局 .container 的 align-items:center，避免内容变窄（需与首页一致） */
  align-items: stretch;
}

.top-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #0077c2 0%, #4facfe 100%);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  z-index: 0;
}

.profile-card {
  position: relative;
  z-index: 1;
  margin-top: 80rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.06);
}

.profile-left-section {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0; 
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f4f8;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.camera-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
}

.camera-icon {
  width: 22rpx;
  height: 22rpx;
}

.info-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
  min-width: 0;
}

.name-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  margin-right: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 300rpx;
}

.edit-btn {
  padding: 4rpx 12rpx;
  background: #f0f2f5;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
}

.edit-icon {
  width: 24rpx;
  height: 24rpx;
}

.meta-wrapper {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
}

.profile-right-section {
  flex-shrink: 0;
  margin-left: 20rpx;
}

.manage-btn {
  display: flex;
  align-items: center;
  background: #eef6ff;
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  color: #0077c2;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.manage-btn .arrow {
  margin-left: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.manage-btn:active {
  background: #dbeaff;
}

.quick-grid {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 30rpx 10rpx;
  display: flex;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.quick-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.quick-item:active {
  opacity: 0.7;
}

.quick-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 16rpx;
}

.quick-text {
  font-size: 26rpx;
  color: #333;
}

.section {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
}

.section-title {
  margin: 0 0 16rpx 16rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
}

.menu-list {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid #f5f7fa;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.left {
  display: flex;
  align-items: center;
}

.icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
}

.left text {
  font-size: 30rpx;
  color: #333;
}

.menu-item.danger .left text {
  color: #333;
}

.menu-item.pressed .left text {
  color: #0077c2;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}

.footer-version {
    text-align: center;
    color: #cbd5e1;
    font-size: 24rpx;
    margin-top: 60rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 99;
  backdrop-filter: blur(2px);
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  z-index: 100;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  height: 88rpx;
  border-radius: 16rpx;
  background: #f5f7fa;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.ghost {
  background: #f0f2f5;
  color: #666;
}

.modal-btn.primary {
  background: #0077c2;
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(0, 119, 194, 0.25);
}

.agreement-modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 101;
}

.agreement-modal {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  z-index: 102;
  box-sizing: border-box;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.16);
  display: flex;
  flex-direction: column;
}

.agreement-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
  margin-bottom: 24rpx;
}

.agreement-modal-body {
  max-height: 48vh;
  min-height: 320rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4b5563;
  padding: 8rpx 8rpx 0;
  box-sizing: border-box;
}

.agreement-modal-btn {
  margin-top: 28rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #0077c2;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(0, 119, 194, 0.25);
}
