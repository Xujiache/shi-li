<view class="container">
  <view class="hero">
    <view class="hero-top">
      <text class="hero-title">青少年健康档案</text>
      <text class="hero-sub">"近视防控光明行动"</text>
    </view>
    <view class="hero-card">
      <view class="hero-left">
        <text class="hero-name">{{form.name || '未填写姓名'}}</text>
        <text class="hero-meta" wx:if="{{age}}">年龄：{{age}}岁</text>
        <text class="hero-meta" wx:else>请先选择出生日期</text>
      </view>
      <view class="hero-right">
        <text class="hero-status">{{canSubmit ? '可提交' : '待完善必填项'}}</text>
      </view>
    </view>
  </view>

  <form bindsubmit="onSubmit">
    <!-- ========== 一、基础信息（始终展开） ========== -->
    <view class="card">
      <view class="card-header" catchtap="toggleSection" data-key="basic">
        <text class="card-title">一、基础信息</text>
        <text class="card-arrow {{sections.basic ? 'open' : ''}}">▸</text>
      </view>
      <view class="card-body {{sections.basic ? 'show' : 'hide'}}">
        <ui-field label="姓名" required value="{{form.name}}" placeholder="请输入姓名" bind:change="onFieldChange" data-field="name" />
        <view class="inline-row">
          <view class="inline-label">性别 <text class="req">*</text></view>
          <radio-group class="radio-group" bindchange="onGenderChange">
            <label class="radio-item"><radio value="男" color="#0077C2" checked="{{form.gender==='男'}}"/>男</label>
            <label class="radio-item"><radio value="女" color="#0077C2" checked="{{form.gender==='女'}}"/>女</label>
          </radio-group>
        </view>
        <ui-picker-field label="出生日期" required mode="date" placeholder="请选择" value="{{form.dob}}" displayText="{{form.dob}}" bind:change="onDatePickerChange" />
        <view class="row-2">
          <view class="col">
            <ui-picker-field label="学校" required range="{{schoolOptions}}" valueIndex="{{school_index}}" displayText="{{form.school}}" placeholder="请选择" helper="{{schoolHelper}}" bind:change="onSchoolPickerChange" disabled="{{schoolOptions.length===0}}" />
          </view>
          <view class="col">
            <ui-picker-field label="班级" required range="{{classOptions}}" valueIndex="{{class_index}}" displayText="{{form.class_name}}" placeholder="{{form.school ? '选择' : '先选学校'}}" helper="{{classHelper}}" bind:change="onClassPickerChange" disabled="{{!form.school || classOptions.length===0}}" />
          </view>
        </view>
        <view class="row-2">
          <view class="col"><ui-field label="身高(cm)" type="digit" value="{{form.height}}" placeholder="cm" bind:change="onFieldChange" data-field="height" /></view>
          <view class="col"><ui-field label="体重(kg)" type="digit" value="{{form.weight}}" placeholder="kg" bind:change="onFieldChange" data-field="weight" /></view>
        </view>
      </view>
    </view>

    <!-- ========== 动态分区（基于配置渲染） ========== -->
    <view
      class="card"
      wx:for="{{dynamicSections}}"
      wx:key="key"
      wx:if="{{item.enabled}}"
      style="order:{{item.sort_order}}"
    >
      <view class="card-header" catchtap="toggleSection" data-key="{{item.key}}">
        <view class="card-title-row">
          <text class="card-title">{{item.label}}</text>
        </view>
        <text class="card-arrow {{sections[item.key] ? 'open' : ''}}">▸</text>
      </view>
      <view class="card-body cfg-body {{sections[item.key] ? 'show' : 'hide'}}">
        <block
          wx:for="{{item.fields}}"
          wx:for-item="field"
          wx:key="key"
          wx:if="{{field.enabled}}"
        >
          <!-- text 类型：文本输入 -->
          <view wx:if="{{field.type === 'text'}}" class="input-item" style="order:{{field.sort_order}}">
            <ui-field
              label="{{field.label}}"
              required="{{field.required}}"
              value="{{formValues[field.key] || ''}}"
              placeholder="{{field.placeholder || '请输入'}}"
              bind:change="onDynamicFieldChange"
              data-field="{{field.key}}"
            />
          </view>

          <!-- number 类型：数字输入 -->
          <view wx:elif="{{field.type === 'number'}}" class="input-item" style="order:{{field.sort_order}}">
            <ui-field
              label="{{field.label}}"
              required="{{field.required}}"
              type="digit"
              value="{{formValues[field.key] || ''}}"
              placeholder="{{field.placeholder || '请输入数字'}}"
              bind:change="onDynamicFieldChange"
              data-field="{{field.key}}"
            />
          </view>

          <!-- select 类型：单选下拉 -->
          <view wx:elif="{{field.type === 'select'}}" class="input-item" style="order:{{field.sort_order}}">
            <text class="field-label">{{field.label}} <text class="req" wx:if="{{field.required}}">*</text></text>
            <picker
              mode="selector"
              range="{{field.options}}"
              value="{{pickerIndexes[field.key] >= 0 ? pickerIndexes[field.key] : 0}}"
              bindchange="onDynamicPickerChange"
              data-field="{{field.key}}"
              data-options="{{field.options}}"
            >
              <view class="picker-box">{{formValues[field.key] || field.placeholder || '请选择'}}</view>
            </picker>
          </view>

          <!-- multi_select 类型：多选标签 -->
          <view wx:elif="{{field.type === 'multi_select'}}" class="input-item" style="order:{{field.sort_order}}">
            <text class="field-label">{{field.label}}（可多选） <text class="req" wx:if="{{field.required}}">*</text></text>
            <view class="pill-row">
              <view
                class="pill {{multiSelectState[field.key + '_' + opt] ? 'on' : ''}}"
                wx:for="{{field.options}}"
                wx:for-item="opt"
                wx:key="*this"
                catchtap="onDynamicMultiToggle"
                data-field="{{field.key}}"
                data-value="{{opt}}"
              >
                <text class="pill-check">{{multiSelectState[field.key + '_' + opt] ? '✓' : ''}}</text>
                <text>{{opt}}</text>
              </view>
            </view>
          </view>

          <!-- date 类型：日期选择 -->
          <view wx:elif="{{field.type === 'date'}}" class="input-item" style="order:{{field.sort_order}}">
            <ui-picker-field
              label="{{field.label}}"
              required="{{field.required}}"
              mode="date"
              placeholder="{{field.placeholder || '请选择日期'}}"
              value="{{formValues[field.key] || ''}}"
              displayText="{{formValues[field.key] || ''}}"
              bind:change="onDynamicDateChange"
              data-field="{{field.key}}"
            />
          </view>

          <!-- textarea 类型：多行文本 -->
          <view wx:elif="{{field.type === 'textarea'}}" class="input-item" style="order:{{field.sort_order}}">
            <text class="field-label">{{field.label}} <text class="req" wx:if="{{field.required}}">*</text></text>
            <textarea
              class="textarea"
              placeholder="{{field.placeholder || '请输入'}}"
              value="{{formValues[field.key] || ''}}"
              bindinput="onDynamicTextarea"
              data-field="{{field.key}}"
            />
          </view>

          <!-- readonly 类型：只读展示 -->
          <view wx:elif="{{field.type === 'readonly'}}" class="input-item" style="order:{{field.sort_order}}">
            <view class="admin-readonly" wx:if="{{formValues[field.key]}}">
              <text class="admin-readonly-title">{{field.label}}</text>
              <view class="admin-plan">{{formValues[field.key]}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 档案分析（AI / 人工） -->
    <view class="analysis-card" wx:if="{{childId}}">
      <view class="analysis-title">📋 档案分析</view>
      <view class="analysis-loading" wx:if="{{analysisLoading}}">加载中…</view>
      <block wx:elif="{{analysis}}">
        <view class="analysis-head">
          <view class="analysis-tag {{analysis.source === 'ai' ? 'tag-ai' : 'tag-human'}}">
            {{analysis.source === 'ai' ? 'AI 分析' : '人工分析'}}
          </view>
          <text class="analysis-time">{{analysis.created_at}}</text>
        </view>
        <view class="analysis-content">{{analysis.content}}</view>
      </block>
      <view wx:else class="analysis-empty">
        暂无分析（管理员尚未生成）
      </view>
    </view>

    <view class="footer">
      <button class="btn-primary" form-type="submit" disabled="{{!canSubmit}}">提交档案</button>
      <view class="footer-tip" wx:if="{{!canSubmit}}">请完善姓名、性别、出生日期、学校、班级后提交</view>
    </view>
  </form>
</view>
