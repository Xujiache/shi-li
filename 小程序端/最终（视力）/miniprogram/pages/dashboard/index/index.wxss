.container {
  padding: 0;
  background: var(--bg-200);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 220rpx;
  position: relative;
  align-items: stretch;
}

.top-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 480rpx;
  background: linear-gradient(180deg, rgba(0, 119, 194, 1) 0%, rgba(89, 165, 245, 0.98) 70%, rgba(245, 245, 245, 0) 100%);
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
  z-index: 0;
}

.main-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 28rpx 24rpx;
}

.hero-top {
  padding: 12rpx 6rpx 28rpx;
}

.hero-title {
  display: block;
  font-size: 46rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 119, 194, 0.4);
}

.hero-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 1rpx;
}

.hero-card {
  width: 100%;
  background: rgba(255, 255, 255, 1);
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 16rpx 40rpx rgba(0, 119, 194, 0.08);
  box-sizing: border-box;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}

.hero-card:active {
  transform: scale(0.98);
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-name {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-100);
  line-height: 1.2;
}

.hero-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-200);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.hero-right {
  margin-left: 20rpx;
  text-align: right;
}

.hero-date {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  color: var(--primary-100);
}

.hero-date-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-200);
}

.hero-cta {
  color: var(--primary-100);
  font-size: 28rpx;
  font-weight: 800;
}

.hero-arrow {
  margin-left: 10rpx;
  color: #cfd8dc;
  font-weight: 800;
}

/* 概览指标卡 */
.metrics {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.metric-card {
  flex: 1;
  min-width: 200rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 30rpx 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 119, 194, 0.08);
  box-sizing: border-box;
}

.k {
  display: block;
  font-size: 24rpx;
  color: var(--text-200);
  font-weight: 600;
}

.v-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.v {
  font-size: 38rpx;
  font-weight: 900;
  color: var(--text-100);
}

.v.small {
  font-size: 32rpx;
}

.t-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
}

.t-wrapper.up {
  background: #f6ffed;
}

.t-wrapper.down {
  background: #fff1f0;
}

.t-wrapper.flat {
  background: #f5f7fa;
}

.t {
  font-size: 22rpx;
  font-weight: 900;
}

.t-wrapper.up .t {
  color: #52c41a;
}

.t-wrapper.down .t {
  color: #ff4d4f;
}

.t-wrapper.flat .t {
  color: var(--text-200);
}

.sub {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #b0bec5;
}

/* 通用卡片 */
.card {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 119, 194, 0.08);
  box-sizing: border-box;
}

.card-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--text-100);
  margin-bottom: 24rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 30rpx 10rpx 10rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  color: var(--text-100);
}

.empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-200);
  margin-bottom: 40rpx;
}

/* 屈光度块 */
.grid-2 {
  display: flex;
  gap: 16rpx;
}

.box {
  flex: 1;
  background: #f8fbff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.box-title {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-100);
  margin-bottom: 16rpx;
}

.kv {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1px dashed rgba(0, 119, 194, 0.1);
}

.kv:last-child {
  border-bottom: none;
}

.kk {
  color: var(--text-200);
  font-size: 24rpx;
  font-weight: 600;
}

.vv {
  color: var(--text-100);
  font-size: 28rpx;
  font-weight: 900;
}

/* 诊断 pill */
.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pill {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-100);
  background: #f0f7ff;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.note {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--text-200);
  line-height: 1.6;
  background: #fafafa;
  padding: 20rpx;
  border-radius: 16rpx;
}

.note.placeholder {
  color: #c0c4cc;
}

/* 按钮组 */
.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-primary,
.btn-outline {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  padding: 0;
  margin: 0;
}

.btn-primary {
  background: var(--primary-100);
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(0, 119, 194, 0.25);
}

.btn-outline {
  background: #f0f7ff;
  color: var(--primary-100);
}

/* 对比卡 */
.compare-card {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 119, 194, 0.08);
  box-sizing: border-box;
}

.compare-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--text-100);
  margin-bottom: 24rpx;
}

.compare-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px dashed rgba(0, 0, 0, 0.06);
}

.compare-row:last-child {
  border-bottom: none;
}

.ck {
  width: 180rpx;
  color: var(--text-200);
  font-size: 26rpx;
  font-weight: 600;
}

.cv,
.cv2 {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-100);
}

.cv2 {
  color: var(--text-200);
  margin-left: 20rpx;
}

.ct-placeholder {
  width: 48rpx;
  margin-left: 12rpx;
}

.ct-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  margin-left: 12rpx;
}

.ct-badge.up {
  background: #f6ffed;
}

.ct-badge.down {
  background: #fff1f0;
}

.ct-badge.flat {
  background: #f5f7fa;
}

.ct {
  font-weight: 900;
  font-size: 24rpx;
}

.ct-badge.up .ct {
  color: #52c41a;
}

.ct-badge.down .ct {
  color: #ff4d4f;
}

.ct-badge.flat .ct {
  color: var(--text-200);
}
