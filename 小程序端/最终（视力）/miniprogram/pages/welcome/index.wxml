<view class="container">
  <view class="top-bg"></view>

  <view class="welcome-wrapper">
    <!-- 品牌区域 -->
    <view class="brand-area">
      <view class="brand-icon">
        <text class="brand-emoji">👁️</text>
      </view>
      <text class="brand-title">儿童视力管理</text>
      <text class="brand-desc">青少年近视防控健康档案系统</text>
    </view>

    <!-- 说明卡片 -->
    <view class="info-card">
      <view class="info-title">使用说明</view>
      <view class="info-item">
        <view class="info-dot"></view>
        <text class="info-text">本小程序仅供已注册的特定用户（学校/机构合作家长）登录使用</text>
      </view>
      <view class="info-item">
        <view class="info-dot"></view>
        <text class="info-text">如您所在学校或机构已开通视力管理服务，请使用已分配的账号登录</text>
      </view>
      <view class="info-item">
        <view class="info-dot"></view>
        <text class="info-text">如需开通服务，请联系您所在学校或机构的管理人员</text>
      </view>
    </view>

    <!-- 功能介绍卡片 -->
    <view class="feature-card">
      <view class="feature-title">核心功能</view>
      <view class="feature-grid">
        <view class="feature-item">
          <text class="feature-icon">📋</text>
          <text class="feature-name">视力档案</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">📅</text>
          <text class="feature-name">预约检查</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">📊</text>
          <text class="feature-name">数据看板</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">📝</text>
          <text class="feature-name">健康问卷</text>
        </view>
      </view>
    </view>

    <!-- 登录按钮 -->
    <button class="btn-login" bindtap="goToLogin">已有账号，进入登录</button>

    <!-- 协议链接 -->
    <view class="terms-area">
      <text class="terms-text">登录即代表您已阅读并同意</text>
      <view class="terms-links">
        <text class="terms-link" bindtap="showUserAgreement">《用户服务协议》</text>
        <text class="terms-link" bindtap="showPrivacyPolicy">《隐私政策》</text>
      </view>
      <view class="terms-links">
        <text class="terms-link" bindtap="showChildPrivacyPolicy">《儿童隐私政策》</text>
        <text class="terms-link" bindtap="showThirdPartyShareList">《第三方信息共享清单》</text>
      </view>
    </view>
  </view>

  <!-- 协议弹窗 -->
  <view class="agreement-modal-mask" wx:if="{{showAgreementModal}}" catchtap="closeAgreementModal"></view>
  <view class="agreement-modal-wrap" wx:if="{{showAgreementModal}}">
    <view class="agreement-modal-content" catchtap="">
      <view class="modal-title">{{agreementTitle}}</view>
      <scroll-view scroll-y class="modal-body">
        <text>{{agreementContent}}</text>
      </scroll-view>
      <button class="btn-close" bindtap="closeAgreementModal">我知道了</button>
    </view>
  </view>
</view>
