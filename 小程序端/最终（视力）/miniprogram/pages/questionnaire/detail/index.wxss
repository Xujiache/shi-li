.container {
  padding: 20rpx;
  background: var(--bg-200, #f5f5f5);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 280rpx;
  padding-bottom: calc(280rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(280rpx + env(safe-area-inset-bottom));
  align-items: stretch;
}

.hero {
  background: linear-gradient(
    135deg,
    #0a67ad 0%,
    #0d76c5 52%,
    #2093ec 100%
  );
  border-radius: 28rpx;
  padding: 28rpx 24rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 119, 194, 0.22);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 12rpx 6rpx 18rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-kicker {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  color: #fff;
  font-size: 22rpx;
  line-height: 1;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.18);
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.96);
}

.hero-icon-wrap {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-icon {
  width: 46rpx;
  height: 46rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 6rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 22rpx;
  line-height: 1;
}

.tag.light {
  background: rgba(255, 255, 255, 0.28);
}

.overview-card,
.card,
.action-card,
.state-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.overview-card {
  display: flex;
  align-items: center;
  padding: 14rpx 10rpx;
}

.overview-item {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 12rpx 6rpx;
}

.overview-value {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.overview-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-200, #888);
}

.overview-divider {
  width: 1rpx;
  height: 52rpx;
  background: rgba(0, 0, 0, 0.08);
}

.card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-copy {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.card-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-200, #888);
}

.head-btn,
.ghost-btn,
.primary-btn {
  height: 76rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 700;
  padding: 0 28rpx;
  margin: 0;
}

.head-btn::after,
.ghost-btn::after,
.primary-btn::after {
  border: none;
}

.head-btn {
  flex-shrink: 0;
  min-width: 160rpx;
  background: #eef6ff;
  color: var(--primary-100, #0077c2);
}

.subject-main {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
}

.subject-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4facfe 0%, #0077c2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.subject-avatar-text {
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
}

.subject-copy {
  flex: 1;
  min-width: 0;
}

.subject-name {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.subject-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-200, #888);
}

.subject-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.mini-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 119, 194, 0.12);
  color: var(--primary-100, #0077c2);
  font-size: 20rpx;
  line-height: 1;
}

.mini-tag.light {
  background: #f3f8fd;
  color: var(--text-200, #888);
}

.info-grid {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  background: #f7fbff;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-200, #888);
}

.info-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-100, #333);
  font-weight: 700;
}

.head-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(0, 119, 194, 0.1);
  color: var(--primary-100, #0077c2);
  font-size: 22rpx;
  font-weight: 700;
}

.section-card + .section-card {
  margin-top: 16rpx;
}

.section-card {
  margin-top: 22rpx;
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  background: #f9fbfe;
  border-radius: 22rpx;
  padding: 20rpx;
}

.section-index {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #eef6ff;
  color: var(--primary-100, #0077c2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.section-body {
  flex: 1;
  min-width: 0;
}

.section-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 700;
  color: var(--text-100, #333);
}

.section-page {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--primary-100, #0077c2);
  background: rgba(0, 119, 194, 0.08);
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
}

.section-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5f6b7a;
}

.section-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.section-meta-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff;
  color: var(--primary-100, #0077c2);
  font-size: 20rpx;
  line-height: 1;
  box-shadow: inset 0 0 0 1rpx rgba(0, 119, 194, 0.08);
}

.section-meta-pill.light {
  color: var(--text-200, #888);
}

.record-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.record-box {
  flex: 1;
  min-width: 0;
  background: #f9fbfe;
  border-radius: 20rpx;
  padding: 22rpx 16rpx;
  text-align: center;
}

.record-value {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.record-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-200, #888);
}

.record-hint {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-200, #888);
}

.action-card {
  margin-top: 20rpx;
  padding: 20rpx;
  display: flex;
  gap: 16rpx;
}

.floating-action-card {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  bottom: calc(20rpx + constant(safe-area-inset-bottom));
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  margin-top: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(18px);
  z-index: 30;
}

.ghost-btn,
.primary-btn {
  flex: 1;
}

.ghost-btn {
  background: #fff;
  color: var(--primary-100, #0077c2);
  border: 2rpx solid rgba(0, 119, 194, 0.14);
}

.primary-btn {
  background: var(--primary-100, #0077c2);
  color: #fff;
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(0, 119, 194, 0.18);
}

.ghost-btn[disabled],
.primary-btn[disabled] {
  opacity: 0.55;
}

.state-card {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.state-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #eef6ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.state-icon {
  width: 44rpx;
  height: 44rpx;
}

.state-title {
  display: block;
  margin-top: 22rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.state-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-200, #888);
}

.state-btn-row {
  width: 100%;
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.state-small-btn {
  min-width: 0;
}