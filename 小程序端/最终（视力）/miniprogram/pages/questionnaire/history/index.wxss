.container {
  padding: 20rpx;
  background: var(--bg-200, #f5f5f5);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 90rpx;
  align-items: stretch;
}

.hero {
  background: linear-gradient(
    135deg,
    #0a67ad 0%,
    #0d76c5 52%,
    #2093ec 100%
  );
  border-radius: 28rpx;
  padding: 28rpx 24rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 119, 194, 0.22);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 12rpx 6rpx 18rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-kicker {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  color: #fff;
  font-size: 22rpx;
  line-height: 1;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.18);
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.96);
}

.hero-icon-wrap {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-icon {
  width: 46rpx;
  height: 46rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 6rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 22rpx;
  line-height: 1;
}

.list-wrap,
.detail-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.submission-card,
.summary-card,
.answer-card,
.empty-state-card,
.state-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.submission-card,
.summary-card,
.answer-card,
.empty-state-card {
  padding: 24rpx;
}

.submission-head,
.summary-main,
.answer-head {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.submission-icon-wrap,
.summary-avatar,
.answer-index,
.empty-icon-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef6ff;
}

.submission-icon-wrap,
.summary-avatar,
.empty-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
}

.answer-index {
  width: 54rpx;
  height: 54rpx;
  border-radius: 16rpx;
  color: var(--primary-100, #0077c2);
  font-size: 24rpx;
  font-weight: 800;
  background: #fff;
  box-shadow: inset 0 0 0 1rpx rgba(0, 119, 194, 0.08);
}

.submission-icon,
.empty-icon {
  width: 34rpx;
  height: 34rpx;
}

.summary-avatar {
  border-radius: 50%;
  background: linear-gradient(135deg, #4facfe 0%, #0077c2 100%);
}

.summary-avatar-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
}

.submission-copy,
.summary-copy,
.answer-copy {
  flex: 1;
  min-width: 0;
}

.submission-title-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.submission-title,
.summary-name,
.answer-title,
.empty-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 800;
  color: var(--text-100, #333);
}

.submission-title {
  flex: 1;
  min-width: 0;
}

.submission-name {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-100, #333);
}

.submission-meta,
.summary-desc,
.summary-time,
.answer-value,
.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-200, #888);
}

.status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 22rpx;
  line-height: 1;
}

.status.submitted {
  background: rgba(0, 119, 194, 0.12);
  color: #0077c2;
}

.status.draft {
  background: rgba(255, 184, 77, 0.16);
  color: #c67a00;
}

.submission-stats,
.summary-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.submission-stat,
.summary-box {
  flex: 1;
  min-width: 0;
  background: #f7fbff;
  border-radius: 18rpx;
  padding: 18rpx 14rpx;
  text-align: center;
}

.submission-stat-value,
.summary-box-value {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.submission-stat-label,
.summary-box-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--text-200, #888);
}

.submission-hint {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-200, #888);
}

.answer-value {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f9fbfe;
  color: var(--text-100, #333);
  font-size: 24rpx;
}

.empty-state-card {
  text-align: center;
}

.empty-icon-wrap {
  margin: 0 auto;
}

.state-card {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.state-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #eef6ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.state-icon {
  width: 44rpx;
  height: 44rpx;
}

.state-title {
  display: block;
  margin-top: 22rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.state-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-200, #888);
}

.state-btn {
  margin-top: 24rpx;
  min-width: 220rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: var(--primary-100, #0077c2);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(0, 119, 194, 0.22);
}

.state-btn::after {
  border: none;
}