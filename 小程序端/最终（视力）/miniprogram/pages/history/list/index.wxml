<view class="container">
  <view class="hero">
    <view class="hero-top">
      <text class="hero-title">数据</text>
      <text class="hero-sub">检测记录 · 趋势对比 · 报告</text>
    </view>

    <view class="hero-card" wx:if="{{childInfo._id}}" bindtap="goToDashboard">
      <view class="hero-card-left">
        <text class="hero-name">{{childInfo.name}}</text>
        <text class="hero-meta">{{childInfo.school}} · {{childInfo.class_name}}</text>
      </view>
      <view class="hero-card-right">
        <text class="hero-cta">查看看板</text>
        <text class="hero-arrow">></text>
      </view>
    </view>

    <view class="hero-card" wx:else bindtap="goToProfile">
      <view class="hero-card-left">
        <text class="hero-name">未完善档案</text>
        <text class="hero-meta">完善后可查看检测数据与趋势</text>
      </view>
      <view class="hero-card-right">
        <text class="hero-cta">去完善</text>
        <text class="hero-arrow">></text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">历史记录</text>
      <text class="section-sub">按时间倒序展示</text>
    </view>

    <view class="record-list" wx:if="{{records.length > 0}}">
      <block wx:for="{{records}}" wx:key="_id">
        <view class="record-card" bindtap="goToRecord" data-record-id="{{item._id}}">
          <view class="record-top">
            <text class="record-date">{{item.date}}</text>
            <view class="record-pill">检测报告</view>
          </view>

          <view class="record-metrics">
            <view class="metric">
              <text class="k">左眼</text>
              <text class="v">{{item.vision_l || '—'}}
                <text class="t {{item.trend_vision_l === 'up' ? 'up' : 'down'}}" wx:if="{{item.trend_vision_l}}">{{item.trend_vision_l === 'up' ? '↑' : '↓'}}</text>
              </text>
            </view>
            <view class="metric">
              <text class="k">右眼</text>
              <text class="v">{{item.vision_r || '—'}}
                <text class="t {{item.trend_vision_r === 'up' ? 'up' : 'down'}}" wx:if="{{item.trend_vision_r}}">{{item.trend_vision_r === 'up' ? '↑' : '↓'}}</text>
              </text>
            </view>
            <view class="metric">
              <text class="k">身高/体重</text>
              <text class="v">{{item.height || '—'}} / {{item.weight || '—'}}</text>
            </view>
          </view>

          <view class="record-bottom" wx:if="{{item.conclusion}}">
            <text class="note">{{item.conclusion}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-title">暂无历史检测数据</text>
      <text class="empty-sub">完成检测后，这里会展示报告与趋势</text>
      <button class="btn-outline" bindtap="goToDashboard" wx:if="{{childInfo._id}}">去看板</button>
      <button class="btn-primary" bindtap="goToProfile" wx:else>去完善档案</button>
    </view>
  </view>
</view>
