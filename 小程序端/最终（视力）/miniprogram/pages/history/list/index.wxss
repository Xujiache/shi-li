.container {
  padding: 20rpx;
  background: var(--bg-200);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 220rpx;
  align-items: stretch;
}

.hero {
  background: linear-gradient(180deg, rgba(0, 119, 194, 1) 0%, rgba(89, 165, 245, 0.98) 55%, rgba(245, 245, 245, 1) 100%);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  padding: 28rpx 24rpx 24rpx;
  margin: -20rpx -20rpx 18rpx;
}

.hero-top {
  padding: 12rpx 6rpx 18rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
}

.hero-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.10);
  box-sizing: border-box;
}

.hero-card:active {
  transform: scale(0.99);
}

.hero-card-left {
  flex: 1;
  min-width: 0;
}

.hero-name {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-100);
}

.hero-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-200);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.hero-card-right {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.hero-cta {
  color: var(--primary-100);
  font-size: 26rpx;
  font-weight: 700;
}

.hero-arrow {
  margin-left: 10rpx;
  color: #cfd8dc;
}

.section {
  margin-top: 10rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 8rpx 4rpx 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100);
}

.section-sub {
  font-size: 24rpx;
  color: var(--text-200);
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(0,0,0,0.06);
}

.record-card:active {
  transform: scale(0.99);
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.record-date {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100);
}

.record-pill {
  font-size: 24rpx;
  color: var(--primary-100);
  background: rgba(0, 119, 194, 0.10);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.record-metrics {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.metric {
  flex: 1;
  background: #f7fbff;
  border-radius: 16rpx;
  padding: 16rpx;
}

.k {
  display: block;
  color: var(--text-200);
  font-size: 24rpx;
}

.v {
  display: block;
  margin-top: 8rpx;
  color: var(--text-100);
  font-size: 28rpx;
  font-weight: 800;
}

.t {
  margin-left: 10rpx;
  font-size: 24rpx;
}

.t.up {
  color: #52c41a;
}

.t.down {
  color: #ff4d4f;
}

.record-bottom {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1px dashed #f0f0f0;
}

.note {
  font-size: 26rpx;
  color: var(--text-200);
  line-height: 1.5;
}

.empty-state {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 26rpx;
  text-align: center;
  box-shadow: 0 8rpx 22rpx rgba(0,0,0,0.06);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100);
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--text-200);
}

.btn-primary {
  background: var(--primary-100);
  color: #fff;
  border-radius: 999rpx;
  margin-top: 18rpx;
}

.btn-outline {
  border: 1px solid var(--primary-100);
  color: var(--primary-100);
  background: #fff;
  border-radius: 999rpx;
  margin-top: 18rpx;
}

