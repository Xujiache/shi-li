.page {
  min-height: 100vh;
  background: var(--bg-200, #f5f5f5);
}

.top-bg {
  height: 160rpx;
  background: var(--primary-100, #0077c2);
}

.wrap {
  padding: 24rpx;
  margin-top: -120rpx;
}

.header-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.header-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-200, #888);
}

.section {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-100, #333);
  padding: 0 0 20rpx;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.child-item {
  position: relative;
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 4rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.child-item.active {
  border: 4rpx solid rgba(0, 119, 194, 0.2);
  background: rgba(0, 119, 194, 0.02);
}

.current-tag {
  position: absolute;
  left: -4rpx;
  top: -4rpx;
  background: var(--primary-100, #0077c2);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 16rpx 0 16rpx 0;
  font-weight: bold;
}

.child-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f2f4f7;
  flex: 0 0 auto;
}

.child-right {
  margin-left: 40rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.child-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  width: 100%;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.child-id {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #888;
  letter-spacing: 2rpx;
}

.btn-manage {
  margin-top: 16rpx;
  width: 260rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--primary-100, #0077c2);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty {
  padding: 60rpx 20rpx;
  text-align: center;
}

.empty-illus {
  width: 320rpx;
  margin: 0 auto 20rpx;
  display: block;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-100, #333);
}

.empty-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-200, #888);
}

.footer {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding-bottom: 60rpx;
}

.btn-primary, .btn-secondary {
  width: 440rpx !important;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 !important;
  padding: 0;
}

.btn-primary {
  background: var(--primary-100, #0077c2);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 119, 194, 0.3);
}

.btn-secondary {
  background: #e5e5e5;
  color: #333;
}
