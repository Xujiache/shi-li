.container {
  padding: 20rpx;
  background: var(--bg-200);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 220rpx;
  align-items: stretch;
}

.hero {
  background: linear-gradient(180deg, rgba(0, 119, 194, 1) 0%, rgba(89, 165, 245, 0.98) 55%, rgba(245, 245, 245, 1) 100%);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  padding: 28rpx 20rpx 24rpx;
  margin: -20rpx -20rpx 18rpx;
}

.hero-top {
  padding: 12rpx 6rpx 18rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
}

.hero-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.10);
  box-sizing: border-box;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-name {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-100);
}

.hero-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-200);
}

.hero-right {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.hero-status {
  font-size: 24rpx;
  font-weight: 800;
  color: var(--primary-100);
}

.hero-action {
  font-size: 24rpx;
  color: var(--text-200);
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(0,0,0,0.06);
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.card-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100);
  margin-bottom: 18rpx;
}

ui-field, ui-picker-field {
  display: block;
  margin-bottom: 18rpx;
}

.input-item {
  margin-bottom: 18rpx;
}

.row-2 {
  display: flex;
  gap: 18rpx;
}

.row-3 {
  display: flex;
  gap: 18rpx;
}

.half {
  flex: 1;
  min-width: 0;
}

.third {
  flex: 1;
  min-width: 0;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  background: var(--bg-200);
  border-radius: 16rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-100);
}

.footer {
  margin-top: 22rpx;
  padding: 8rpx 6rpx 0;
  width: 100%;
}

.btn-primary {
  width: 100%;
  background: var(--primary-100);
  color: #fff;
  border-radius: 999rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 800;
  padding: 0;
  box-shadow: 0 12rpx 26rpx rgba(0, 119, 194, 0.22);
}

.btn-primary:active {
  background: var(--primary-200);
}

.footer-tip {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--text-200);
  text-align: center;
}
