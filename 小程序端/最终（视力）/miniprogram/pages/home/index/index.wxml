<view class="container">
  <view class="top-bg"></view>
  <view class="main-content">
    <view class="hero-top">
      <view class="hero-title">儿童视力管理</view>
      <view class="hero-sub">一站式视力档案 · 预约 · 数据看板</view>
    </view>

    <!-- 首页骨架屏 -->
    <block wx:if="{{isLoading}}">
      <!-- 轮播骨架 -->
      <view class="sk-pulse" style="height: 340rpx; border-radius: 40rpx; margin-bottom: 24rpx; width: 100%;"></view>
      
      <!-- 个人卡片骨架 -->
      <view style="height: 200rpx; border-radius: 40rpx; margin-bottom: 24rpx; padding: 40rpx; display: flex; align-items: center; box-sizing: border-box; background: rgba(255,255,255,0.95);">
         <view class="sk-pulse" style="width: 100rpx; height: 100rpx; border-radius: 50rpx; margin-right: 30rpx;"></view>
         <view style="flex: 1;">
            <view class="sk-pulse" style="width: 40%; height: 36rpx; border-radius: 8rpx; margin-bottom: 20rpx;"></view>
            <view class="sk-pulse" style="width: 65%; height: 24rpx; border-radius: 8rpx;"></view>
         </view>
      </view>

      <!-- 金刚区骨架 -->
      <view style="border-radius: 40rpx; padding: 50rpx 10rpx 10rpx; box-sizing: border-box; display: flex; flex-wrap: wrap; background: rgba(255,255,255,0.95);">
         <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" style="width: 33.33%; display: flex; flex-direction: column; align-items: center; margin-bottom: 40rpx;">
            <view class="sk-pulse" style="width: 90rpx; height: 90rpx; border-radius: 28rpx; margin-bottom: 20rpx;"></view>
            <view class="sk-pulse" style="width: 70rpx; height: 24rpx; border-radius: 8rpx;"></view>
         </view>
      </view>
    </block>

    <!-- 真实内容展示 -->
    <block wx:else>
      <view class="banner-card">
        <swiper wx:if="{{banners.length > 0}}" class="banner-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{3000}}" duration="{{500}}" circular="{{true}}">
          <block wx:for="{{banners}}" wx:key="_id">
            <swiper-item>
              <view class="banner-item">
                <image src="{{item.image_url}}" class="banner-image" mode="aspectFill"></image>
                <view class="banner-mask" wx:if="{{item.title || item.sub_title}}"></view>
                <view class="banner-text" wx:if="{{item.title || item.sub_title}}">
                  <text class="banner-title" wx:if="{{item.title}}">{{item.title}}</text>
                  <text class="banner-sub" wx:if="{{item.sub_title}}">{{item.sub_title}}</text>
                </view>
              </view>
            </swiper-item>
          </block>
        </swiper>
        <view class="banner-empty" wx:else>暂无活动</view>
      </view>

      <view class="hero-card">
        <view class="hero-card-top">
          <view class="hero-avatar-wrap">
            <view class="hero-avatar-text">{{childInfo.name ? childInfo.name[0] : '?'}}</view>
          </view>
          <view class="hero-info">
            <view class="hero-name">{{childInfo._id ? childInfo.name : '未完善档案'}}</view>
            <view class="hero-meta" wx:if="{{childInfo._id}}">{{childInfo.school}} · {{childInfo.class_name}}</view>
            <view class="hero-meta" wx:else>完善档案后可使用预约与看板功能</view>
          </view>
        </view>
        <view class="hero-card-btns">
          <button class="btn-edit" bindtap="goToProfile">
            <text>{{childInfo._id ? '编辑档案' : '去完善'}}</text>
          </button>
          <view class="btn-divider"></view>
          <button class="btn-switch" bindtap="goSelectChild">
            <text>切换孩子</text>
          </button>
        </view>
      </view>

      <view class="action-grid">
        <view class="action-item" bindtap="goToAppointment">
          <image class="action-icon" src="/images/icons/appointment.svg" mode="aspectFit"></image>
          <text class="action-text">预约报名</text>
        </view>
        <view class="action-item" bindtap="goToDashboard">
          <image class="action-icon" src="/images/icons/dashboard.svg" mode="aspectFit"></image>
          <text class="action-text">健康看板</text>
        </view>
        <view class="action-item" bindtap="goToQuestionnaire">
          <image class="action-icon" src="/images/icons/question.svg" mode="aspectFit"></image>
          <text class="action-text">问卷中心</text>
        </view>
        <view class="action-item" bindtap="goToRecordArchive">
          <image class="action-icon" src="/images/icons/record-archive.svg" mode="aspectFit"></image>
          <text class="action-text">记录档案</text>
        </view>
        <view class="action-item" bindtap="goToAppointments">
          <image class="action-icon" src="/images/icons/records.svg" mode="aspectFit"></image>
          <text class="action-text">我的预约</text>
        </view>
        <view class="action-item" bindtap="goToProfile">
          <image class="action-icon" src="/images/icons/profile.svg" mode="aspectFit"></image>
          <text class="action-text">档案管理</text>
        </view>
      </view>
    </block>
  </view>
</view>
