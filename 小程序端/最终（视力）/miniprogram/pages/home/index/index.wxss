.container {
  padding: 0;
  background: var(--bg-200);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 220rpx;
  position: relative;
  align-items: stretch;
}

.top-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 480rpx;
  background: linear-gradient(180deg, rgba(0, 119, 194, 1) 0%, rgba(89, 165, 245, 0.98) 70%, rgba(245, 245, 245, 0) 100%);
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
  z-index: 0;
}

.main-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 28rpx 24rpx;
}

.hero-top {
  padding: 12rpx 6rpx 28rpx;
}

.hero-title {
  font-size: 46rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 119, 194, 0.4);
}

.hero-sub {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 1rpx;
}

.banner-card {
  width: 100%;
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(0, 119, 194, 0.08);
  margin-bottom: 32rpx;
  transform: translateY(0);
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
  border-radius: 28rpx;
  overflow: hidden;
  transform: translateY(0); 
}

.banner-item {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 320rpx;
  display: block;
  border-radius: 28rpx;
}

.banner-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  background: linear-gradient(180deg, rgba(0,0,0,0) 45%, rgba(0,0,0,0.5) 100%);
  border-radius: 28rpx;
}

.banner-text {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 24rpx;
  z-index: 2;
  color: #fff;
}

.banner-title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  text-shadow: 0 6rpx 16rpx rgba(0,0,0,0.4);
}

.banner-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  opacity: 0.92;
  text-shadow: 0 6rpx 14rpx rgba(0,0,0,0.4);
}

.banner-empty {
  padding: 40rpx;
  text-align: center;
  color: var(--text-200);
  background: #f8fbff;
}

.hero-card {
  width: 100%;
  background: rgba(255, 255, 255, 1);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(0, 119, 194, 0.08);
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.hero-card-top {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 28rpx;
}

.hero-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4facfe 0%, #0077c2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(0, 119, 194, 0.2);
}

.hero-avatar-text {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.hero-info {
  flex: 1;
  min-width: 0;
}

.hero-name {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-100);
  line-height: 1.2;
}

.hero-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-200);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.hero-card-btns {
  display: flex;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.btn-edit {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--primary-100);
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 0;
}

.btn-edit:active {
  background: #f0f7ff;
}

.btn-divider {
  width: 1rpx;
  background: rgba(0, 0, 0, 0.04);
  margin: 20rpx 0;
}

.btn-switch {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-100);
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 0;
}

.btn-switch:active {
  background: #f5f7fa;
}

.action-grid {
  width: 100%;
  background: rgba(255, 255, 255, 1);
  border-radius: 28rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  box-shadow: 0 16rpx 40rpx rgba(0, 119, 194, 0.05);
  box-sizing: border-box;
}

.action-item {
  width: 33.33%;
  height: 170rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.action-item:active {
  background: #f0f7ff;
  transform: scale(0.98);
}

.action-icon {
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 6rpx;
}

.action-text {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--text-100);
  font-weight: 600;
}
