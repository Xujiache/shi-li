<view class="container">
  <view class="top-bg"></view>
  
  <view class="login-wrapper">
    <view class="header">
      <text class="title">您好，</text>
      <text class="subtitle">欢迎使用儿童视力管理体系</text>
      <text class="header-notice">本系统仅限已注册的学校/机构合作家长登录使用</text>
    </view>

    <view class="login-box {{isRegister ? 'register-mode' : ''}}">
      <view class="form-group">
        <ui-field label="手机号" type="number" value="{{phone}}" placeholder="请输入手机号" bind:change="onPhoneFieldChange" />
        <view class="gap"></view>
        <ui-field label="密码" password value="{{password}}" placeholder="请输入密码" bind:change="onPasswordFieldChange" />
        
        <!-- 密码强度条 -->
        <view class="strength-bar" wx:if="{{password.length > 0 && isRegister}}">
          <view class="strength-fill strength-{{strengthLevel}}" style="width: {{strengthWidth}}%"></view>
        </view>
        <view class="strength-text" wx:if="{{password.length > 0 && isRegister}}">
          密码强度: {{strengthText}}
        </view>

        <!-- 确认密码 -->
        <view class="gap" wx:if="{{isRegister}}"></view>
        <ui-field wx:if="{{isRegister}}" label="确认密码" password value="{{confirmPassword}}" placeholder="请再次输入密码" bind:change="onConfirmPasswordFieldChange" />

        <!-- 记住密码 -->
        <view class="remember-box" wx:if="{{!isRegister}}">
           <checkbox-group bindchange="onRememberChange">
             <label class="remember-label">
               <checkbox value="remember" checked="{{rememberLogin}}" color="#0077C2" style="transform:scale(0.8)"/>
               <text>记住登录</text>
             </label>
           </checkbox-group>
        </view>
      </view>

      <view class="agreement">
        <checkbox-group bindchange="onAgreementChange">
          <checkbox value="agreed" checked="{{agreed}}" color="#0077C2" style="transform:scale(0.8)"/>
        </checkbox-group>
        <view class="agreement-text">
          <block wx:if="{{isRegister}}">
            注册代表同意
            <text class="link" bindtap="showUserAgreement">用户协议</text>、
            <text class="link" bindtap="showPrivacyPolicy">隐私政策</text>、
            <text class="link" bindtap="showChildPrivacyPolicy">儿童隐私政策</text>、
            <text class="link" bindtap="showThirdPartyShareList">第三方信息共享清单</text>
          </block>
          <block wx:else>
            我已阅读并同意
            <text class="link" bindtap="showUserAgreement">《用户协议》</text>
            和
            <text class="link" bindtap="showPrivacyPolicy">《隐私政策》</text>
          </block>
        </view>
      </view>

      <button class="btn-primary" bindtap="handleAction">
        {{ isRegister ? '立即注册' : '登录' }}
      </button>

      <view class="switch-mode" bindtap="switchMode">
        <text>{{ isRegister ? '已有账号？' : '没有账号？' }}<text class="highlight">{{ isRegister ? '去登录' : '去注册' }}</text></text>
      </view>
      
      <view class="divider" wx:if="{{!isRegister}}">
        <text>或</text>
      </view>

      <view class="wechat-login" bindtap="handleWechatLogin" wx:if="{{!isRegister}}">
         <image class="wechat-icon" src="/images/wechat_login.svg"></image>
         <text class="wechat-label">微信登录</text>
      </view>
    </view>
  </view>

  <!-- 协议弹窗（用 view 实现，避免 page-container 全应用仅能存在一个的限制） -->
  <view class="agreement-modal-mask" wx:if="{{showAgreementModal}}" catchtap="closeAgreementModal"></view>
  <view class="agreement-modal-wrap" wx:if="{{showAgreementModal}}">
    <view class="agreement-modal-content" catchtap="">
      <view class="modal-title">{{agreementTitle}}</view>
      <scroll-view scroll-y class="modal-body">
        <text>{{agreementContent}}</text>
      </scroll-view>
      <button class="btn-close" bindtap="closeAgreementModal">我知道了</button>
    </view>
  </view>
</view>
