/* app.wxss transition support */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--bg-200);
  position: relative;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 540rpx;
  background: linear-gradient(180deg, rgba(0, 119, 194, 1) 0%, rgba(89, 165, 245, 0.98) 70%, rgba(245, 245, 245, 0) 100%);
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
  z-index: 0;
}

.login-wrapper {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 76rpx 24rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.header {
  margin-bottom: 72rpx;
  padding-left: 20rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #fff;
  display: block;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 119, 194, 0.4);
}

.subtitle {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-top: 16rpx;
  display: block;
  letter-spacing: 1rpx;
}

.header-notice {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 16rpx;
  display: block;
  background: rgba(255, 255, 255, 0.15);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  line-height: 1.5;
}

.login-box {
  background: rgba(255, 255, 255, 0.98);
  padding: 76rpx 48rpx 100rpx;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 119, 194, 0.12);
  width: 100%;
  box-sizing: border-box;
  transition: all 0.3s ease;
  backdrop-filter: blur(20px);
}

.form-group {
  width: 100%;
}

.gap {
  height: 48rpx;
}

/* Password Strength */
.strength-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.strength-fill {
  height: 100%;
  transition: width 0.3s ease, background-color 0.3s ease;
}

.strength-low { background-color: #ff4d4f; }
.strength-medium { background-color: #faad14; }
.strength-high { background-color: #52c41a; }

.strength-text {
  font-size: 22rpx;
  color: var(--text-200);
  margin-top: 8rpx;
  text-align: right;
}

.confirm-pwd {
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

.agreement {
  display: flex;
  align-items: flex-start;
  margin-top: 24rpx;
  margin-bottom: 64rpx;
  width: 100%;
}

.agreement-text {
  font-size: 24rpx;
  color: var(--text-200);
  margin-left: 12rpx;
  line-height: 1.6;
  flex: 1;
}

.remember-box {
  margin-top: 20rpx;
  width: 100%;
}

.remember-label {
  display: flex;
  align-items: center;
}

.remember-label text {
  font-size: 26rpx;
  color: var(--text-200);
  margin-left: 12rpx;
}

.link {
  color: var(--primary-100);
  display: inline;
  font-weight: 600;
}

.btn-primary {
  width: 100% !important;
  height: 100rpx;
  line-height: 100rpx;
  background: var(--primary-100);
  color: white;
  border-radius: 999rpx;
  padding: 0;
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
  box-shadow: 0 10rpx 24rpx rgba(0, 119, 194, 0.25);
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  display: block;
  box-sizing: border-box;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 10rpx rgba(0, 119, 194, 0.15);
}

.switch-mode {
  margin-top: 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-200);
  font-weight: 500;
}

.switch-mode .highlight {
  color: var(--primary-100);
  font-weight: 800;
}

.switch-mode:active {
  opacity: 0.7;
}

.divider {
  margin: 64rpx 0 48rpx;
  text-align: center;
  position: relative;
}

.divider text {
  background: #fff;
  padding: 0 24rpx;
  color: #ccc;
  font-size: 24rpx;
  position: relative;
  z-index: 1;
}

.divider::after {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  width: 100%;
  height: 1px;
  background: #f0f0f0;
  z-index: 0;
}

.wechat-login {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.wechat-login:active {
  transform: scale(0.96);
}

.wechat-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 16rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
}

.wechat-label {
  font-size: 26rpx;
  color: var(--text-200);
  font-weight: 500;
}

/* 协议弹窗（替代 page-container） */
.agreement-modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(2px);
  z-index: 9998;
}

.agreement-modal-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.agreement-modal-content {
  width: 100%;
  max-height: 75vh;
  padding: 50rpx 40rpx;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text-100);
  margin-bottom: 30rpx;
  text-align: center;
}

.modal-body {
  flex: 1;
  height: 50vh;
  font-size: 28rpx;
  color: var(--text-200);
  line-height: 1.65;
  margin-bottom: 40rpx;
}

.btn-close {
  background: var(--primary-100);
  color: white;
  width: 100%;
  border-radius: 999rpx;
  height: 88rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 119, 194, 0.2);
}
