.container {
  padding: 20rpx;
  background: var(--bg-200);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 220rpx;
  align-items: stretch;
}

.header {
  margin: 16rpx 4rpx 18rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-100);
}

.sub {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--text-200);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.item-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.item-card:active {
  transform: scale(0.99);
}

.name {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-100);
}

.desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--text-200);
}

.right {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.visual {
  position: relative;
  width: 176rpx;
  height: 104rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f2f4f7;
  flex: 0 0 auto;
}

.visual-img {
  width: 100%;
  height: 100%;
}

.visual-fade {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to right, rgba(255,255,255,1) 0%, rgba(255,255,255,0.0) 70%);
}

.visual-tint {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to left, rgba(0,119,194,0.18) 0%, rgba(0,119,194,0.00) 55%);
}

.arrow {
  color: #cfcfcf;
  font-size: 38rpx;
}

.empty {
  text-align: center;
  margin-top: 120rpx;
}

.empty-text {
  color: var(--text-200);
  font-size: 28rpx;
}
