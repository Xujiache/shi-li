.container {
  padding: 20rpx;
  background: var(--bg-200);
  min-height: 100vh;
  box-sizing: border-box;
  align-items: stretch;
  padding-bottom: 220rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid #f0f0f0;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary-100);
  border-left: 8rpx solid var(--primary-100);
  padding-left: 16rpx;
}

ui-field, ui-picker-field {
  display: block;
}

.btn-submit {
  background: var(--primary-100);
  color: #fff;
  margin-top: 24rpx;
  border-radius: 999rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 800;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gap {
  height: 16rpx;
}

.btn-submit[disabled] {
  background: #b6c8d7;
  color: #fff;
}

.empty-profile {
  background: #f5faff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  color: var(--text-200);
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.btn-outline {
  border: 1px solid var(--primary-100);
  color: var(--primary-100);
  background: #fff;
  border-radius: 40rpx;
}
