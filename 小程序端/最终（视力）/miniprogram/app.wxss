/**app.wxss**/
page {
  /* UI 配色规范 */
  --primary-100: #0077C2;
  --primary-200: #59a5f5;
  --primary-300: #c8ffff;
  --accent-100: #00BFFF;
  --accent-200: #00619a;
  --text-100: #333333;
  --text-200: #5c5c5c;
  --bg-100: #FFFFFF;
  --bg-200: #f5f5f5;
  --bg-300: #cccccc;

  background: var(--bg-200);
  color: var(--text-100);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei',
    sans-serif;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding: 32rpx;
  width: 100%;
}

button {
  background: initial;
  transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.22s ease, box-shadow 0.22s ease;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}

button:active {
  transform: translateY(2rpx) scale(0.985);
  opacity: 0.96;
}
